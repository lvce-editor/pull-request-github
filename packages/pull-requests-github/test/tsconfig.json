{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "assumeChangesOnlyAffectDirectDependencies": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "noUncheckedSideEffectImports": true,
    "strict": true,
    "types": ["node"]
  },
  "include": ["../src", "."]
}
