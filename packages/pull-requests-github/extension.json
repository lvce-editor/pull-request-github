{
  "id": "github.pull-requests",
  "browser": "dist/pullRequestWorkerMain.js",
  "isolated": true,
  "activation": [
    "onView:github.pullRequests",
    "onCommand:PullRequestsGithub.openOnGitHub",
    "onCommand:PullRequestsGithub.refresh",
    "onCommand:PullRequestsGithub.show"
  ],
  "commands": [
    {
      "id": "PullRequestsGithub.show",
      "label": "GitHub Pull Requests: Focus on Pull Requests View"
    },
    {
      "id": "PullRequestsGithub.refresh",
      "label": "GitHub Pull Requests: Refresh Pull Request"
    },
    {
      "id": "PullRequestsGithub.openOnGitHub",
      "label": "GitHub Pull Requests: Open Pull Request on GitHub"
    },
    {
      "id": "PullRequestsGithub.clearPullRequestData",
      "label": "Clear Pull Requests GitHub Mock Data"
    },
    {
      "id": "PullRequestsGithub.setPullRequestData",
      "label": "Set Pull Requests GitHub Mock Data"
    },
    {
      "id": "PullRequestsGithub.setPullRequestError",
      "label": "Set Pull Requests GitHub Mock Error"
    }
  ],
  "views": [
    {
      "id": "github.pullRequests",
      "title": "Pull Requests",
      "icon": "symbol-github",
      "kind": "virtualDom"
    }
  ]
}
